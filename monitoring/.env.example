# pg_trickle monitoring stack — example environment variables
#
# Copy this file to .env and fill in secure values before running
# `docker compose up` in a shared or production environment.
#
# IMPORTANT: The defaults below are intentionally insecure and MUST be
# changed for any non-local deployment. Hardcoded default credentials
# are acceptable ONLY for local development on a loopback interface.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
# CHANGE this password for any shared or production environment.
POSTGRES_PASSWORD=postgres
POSTGRES_DB=demo

# ── Grafana ─────────────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
# CHANGE this password for any shared or production environment.
GF_ADMIN_PASSWORD=admin
